# 从控制台复制完整 API Key（不要带引号）
MINIMAX_API_KEY=

# OpenAI 兼容接口根地址（与 Anthropic/Claude 的 …/anthropic 不是同一路径）
# 国内 https://platform.minimaxi.com → https://api.minimaxi.com/v1
# 国际 https://platform.minimax.io → https://api.minimax.io/v1

MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# 默认 true（流式）。本项目已用 fetch+SSE 直连，一般无需关闭
# MINIMAX_STREAM=false

# Agent 天气工具：易客天气 https://www.yiketianqi.com （勿将密钥提交到 Git）
YIKETIANQI_APPID=
YIKETIANQI_APPSECRET=
